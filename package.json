{
  "name": "autobattler",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "pretest": "npm run typecheck",
    "test": "vitest run --reporter=verbose",
    "typecheck": "tsc --build",
    "dev": "npm run dev --workspace=packages/client",
    "server": "tsx packages/server/src/index.ts",
    "balance": "tsx packages/balance/src/cli.ts"
  },
  "devDependencies": {
    "tsx": "^4.11.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
